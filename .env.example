LLM_PROVIDER=mock

# Phase 12/13 market data provider framework. External providers are disabled by default.
MARKET_DATA_PROVIDER=mock_market_data
MARKET_DATA_ENABLED=true
MARKET_DATA_TIMEOUT_SECONDS=10
MARKET_DATA_ALLOW_EXTERNAL=false
POLYGON_API_KEY=
ALPACA_DATA_API_KEY=
ALPACA_DATA_API_SECRET=
NEWS_PROVIDER_API_KEY=
SEC_PROVIDER_ENABLED=false

# Optional Phase 13 Yahoo Finance/yfinance read-only provider.
# This provider does not need an API key, but it makes external network requests.
# MARKET_DATA_PROVIDER=yahoo_finance
# MARKET_DATA_ENABLED=true
# MARKET_DATA_ALLOW_EXTERNAL=true

# Phase 14 news, SEC filing, and risk event providers. External providers are disabled by default.
NEWS_PROVIDER=mock_news_provider
NEWS_PROVIDER_ENABLED=true
NEWS_ALLOW_EXTERNAL=false
NEWS_TIMEOUT_SECONDS=10
SEC_FILING_PROVIDER=mock_sec_filing_provider
SEC_FILING_ENABLED=true
SEC_ALLOW_EXTERNAL=false
SEC_TIMEOUT_SECONDS=10
RISK_EVENT_DETECTOR_ENABLED=true
FINNHUB_API_KEY=

# Local LLM through an OpenAI-compatible endpoint such as Ollama or vLLM.
# Use a model that is actually listed by /v1/models, for example qwen3:8b on Ollama.
# LLM_PROVIDER=local_openai_compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3:8b
# LLM_API_KEY=local
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_TOKENS=1200

# Telegram report delivery is disabled by default.
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=10

# External bot webhook receiver is disabled by default.
WEBHOOKS_ENABLED=false
WEBHOOK_SECRET=change-me
WEBHOOK_REQUIRE_SECRET=true
