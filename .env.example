LLM_PROVIDER=mock

# Local LLM through an OpenAI-compatible endpoint such as Ollama or vLLM.
# Use a model that is actually listed by /v1/models, for example qwen3:8b on Ollama.
# LLM_PROVIDER=local_openai_compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen3:8b
# LLM_API_KEY=local
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_TOKENS=1200

# Telegram report delivery is disabled by default.
TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=10

# External bot webhook receiver is disabled by default.
WEBHOOKS_ENABLED=false
WEBHOOK_SECRET=change-me
WEBHOOK_REQUIRE_SECRET=true
